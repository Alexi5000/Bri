# EditorConfig is awesome: https://EditorConfig.org
# One file, one canonical style. Pair with pyproject.toml [tool.ruff] for Python.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.py]
indent_size = 4
max_line_length = 100

[*.md]
trim_trailing_whitespace = false  # markdown uses two trailing spaces for hard line breaks

[*.{yml,yaml,toml}]
indent_size = 2

[*.{svg,css,html,json}]
indent_size = 2

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf